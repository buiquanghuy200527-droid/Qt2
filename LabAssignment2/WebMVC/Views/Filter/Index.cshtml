@{
    ViewBag.Title = "Thống kê";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h3>📊 Thống kê Hệ thống</h3>

    <ul class="nav nav-tabs mt-3" id="filterTab">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#tab1">Sản phẩm bán chạy</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tab2">Đại lý mua nhiều nhất</a>
        </li>
    </ul>

    <div class="tab-content border border-top-0 p-3 bg-white">

        <div class="tab-pane active" id="tab1">
            <table class="table table-striped table-hover mt-2">
                <thead class="table-dark">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Tổng SL đã bán</th>
                        <th>Doanh thu mang lại</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.BestItems)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td><span class="badge bg-success">@item.TongSL</span></td>
                            <td class="text-danger fw-bold">@string.Format("{0:N0}", item.DoanhThu) đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="tab-pane" id="tab2">
            <table class="table table-striped table-hover mt-2">
                <thead class="table-primary">
                    <tr>
                        <th>Tên Đại lý</th>
                        <th>Số đơn đã đặt</th>
                        <th>Tổng tiền thanh toán</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in ViewBag.TopAgents)
                    {
                        <tr>
                            <td>@a.AgentName</td>
                            <td><span class="badge bg-info text-dark">@a.SoDon đơn</span></td>
                            <td class="text-danger fw-bold">@string.Format("{0:N0}", a.TongTien) đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>