@model IEnumerable<WebMVC_Core.Models.Item>

@{
    ViewData["Title"] = "Items List";
}

<div class="container mt-4">
    <h2>Items Catalog</h2>
    
    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Item</a>
    </p>

    <table class="table table-striped table-hover">
        <thead class="thead-dark">
        <tr>
            <th>ID</th>
            <th>Item Name</th>
            <th>Size</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ItemID</td>
                <td>@item.ItemName</td>
                <td>@item.Size</td>
            </tr>
        }
        </tbody>
    </table>
</div>